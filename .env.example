# ============================================
# Django Settings
# ============================================
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,*.ngrok.io

# ============================================
# Database (PostgreSQL for production, SQLite for dev)
# ============================================
# For Render deployment, use DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# For local PostgreSQL development:
DB_NAME=malice_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# ============================================
# Email Settings (for OTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@malice.com

# ============================================
# Twilio SMS Settings (for OTP)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Stripe Payment Settings
# ============================================
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# PayPal Settings
# ============================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ============================================
# GCash/Xendit Settings
# ============================================
XENDIT_SECRET_KEY=xnd_development_your_xendit_key
XENDIT_PUBLIC_KEY=xnd_public_development_your_xendit_public_key

# ============================================
# PayMongo Settings
# ============================================
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public

# ============================================
# Maya Settings
# ============================================
MAYA_PUBLIC_API_KEY=pk-MayaPublicKey
MAYA_SECRET_API_KEY=sk-MayaSecretKey

# ============================================
# Redis Settings (for caching & Celery)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# AWS S3 Settings (optional - for media storage)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
